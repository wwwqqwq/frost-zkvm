# Proof backend (real provers only):
# `cpu`     — local STARK prover on the CPU (recommended for `--proof-type core`).
# `cuda`    — local STARK prover on a CUDA GPU.
# `network` — Succinct Prover Network (recommended for compressed / groth16).
SP1_PROVER=cpu

# To use the Succinct Prover Network, set the private key of the account you
# want to use for requesting proofs.
# Set up a new account here: https://docs.succinct.xyz/docs/network/developers/key-setup.
NETWORK_PRIVATE_KEY=